{

	// Content //////////////////////////////////////////////////////////

	"Changes": [

		// Lobby Map Load //////////////////////////////////////////////////////////
		// Central Station warp is in tmx file map properties

		{
			"Action": "Load",
			"Target": "Maps/{{ModId}}_Lobby",
			"FromFile": "maps/Lobby.tmx",
		},
		{
			"Action": "EditData",
			"Target": "Data/Locations",
			"Entries": {
				"{{ModId}}_Lobby": {
					"DisplayName": "Escape Room Lobby",						
					"CreateOnLoad": { 
						"MapPath": "Maps/{{ModId}}_Lobby" 
					},
					"DefaultArrivalTile": {
						"X": 5,
						"Y": 9
					},
					// "MusicDefault": "Hospital_Ambient",
				},
			},
		},

		// Ticket Shop //////////////////////////////////////////////////////////

		{
			"Action": "EditMap",
			"Target": "Maps/{{ModId}}_Lobby",
			"MapTiles": [
				{
					"Position": { "X": 12, "Y": 5 },
					"Layer": "Buildings",
					"SetProperties": {
						"Action": "OpenShop {{ModId}}_TicketShop none 600 2600 12 5 1 1"
					}
				},
			],
		},

		{
			"Action": "EditData",
			"Target": "Data/Shops",
			"Entries": {
				"{{ModId}}_TicketShop": {
					"Id": "{{ModId}}_TicketShop",
					"Owners": [
						{
							"Id": "{{ModId}}_Open",
							"Name": "AnyOrNone",
							"Dialogues": [],
						},
					],
					"Items": [
						{
							"Id": "{{ModId}}_TicketShopCoffee",
							"ItemId": "(O)395",
							"AvailableStock": 2,
							"AvailableStockLimit": "Player",
						},
					],
				},
			}
		},

		// Rooms //////////////////////////////////////////////////////////

		// Maze Room
		{
			"Action": "Include",
			"FromFile": "rooms/MazeRoom.json",
		},

	// End //////////////////////////////////////////////////////////

	]

}